{
  "entries": [
    {
      "id": "gh-cli",
      "name": "gh",
      "kind": "cli",
      "binary": "gh",
      "install": ["brew", "install", "gh"],
      "verify": ["gh", "--version"],
      "manual_install": "brew install gh"
    },
    {
      "id": "task-cli",
      "name": "task",
      "kind": "cli",
      "binary": "task",
      "detect": ["task", "--help"],
      "detect_contains": "Runs the specified task(s).",
      "install": ["brew", "install", "go-task"],
      "verify": ["task", "--help"],
      "verify_contains": "Runs the specified task(s).",
      "manual_install": "brew install go-task"
    },
    {
      "id": "mise-cli",
      "name": "mise",
      "kind": "cli",
      "binary": "mise",
      "install": ["brew", "install", "mise"],
      "verify": ["mise", "--version"],
      "manual_install": "brew install mise"
    },
    {
      "id": "lefthook-cli",
      "name": "lefthook",
      "kind": "cli",
      "binary": "lefthook",
      "install": ["brew", "install", "lefthook"],
      "verify": ["lefthook", "version"],
      "manual_install": "brew install lefthook"
    },
    {
      "id": "uv-cli",
      "name": "uv",
      "kind": "cli",
      "binary": "uv",
      "install": ["brew", "install", "uv"],
      "verify": ["uv", "--version"],
      "manual_install": "brew install uv"
    },
    {
      "id": "ruff-cli",
      "name": "ruff",
      "kind": "cli",
      "binary": "ruff",
      "install": ["brew", "install", "ruff"],
      "verify": ["ruff", "--version"],
      "manual_install": "brew install ruff"
    },
    {
      "id": "biome-cli",
      "name": "biome",
      "kind": "cli",
      "binary": "biome",
      "package": "@biomejs/biome",
      "local_bin": "node_modules/.bin/biome",
      "install": ["npm", "install", "--save-dev", "@biomejs/biome"],
      "verify": ["npx", "biome", "--version"],
      "manual_install": "npm install --save-dev @biomejs/biome"
    },
    {
      "id": "nx-cli",
      "name": "nx",
      "kind": "cli",
      "binary": "nx",
      "package": "nx",
      "local_bin": "node_modules/.bin/nx",
      "install": ["npm", "install", "--save-dev", "nx"],
      "verify": ["npx", "nx", "--version"],
      "manual_install": "npm install --save-dev nx"
    },
    {
      "id": "supabase-cli",
      "name": "supabase",
      "kind": "cli",
      "binary": "supabase",
      "install": ["brew", "install", "supabase/tap/supabase"],
      "verify": ["supabase", "--version"],
      "manual_install": "brew install supabase/tap/supabase"
    },
    {
      "id": "vercel-cli",
      "name": "vercel",
      "kind": "cli",
      "binary": "vercel",
      "package": "vercel",
      "local_bin": "node_modules/.bin/vercel",
      "install": ["npm", "install", "--save-dev", "vercel"],
      "verify": ["npx", "vercel", "--version"],
      "manual_install": "npm install --save-dev vercel"
    },
    {
      "id": "stripe-cli",
      "name": "stripe",
      "kind": "cli",
      "binary": "stripe",
      "install": ["brew", "install", "stripe/stripe-cli/stripe"],
      "verify": ["stripe", "version"],
      "manual_install": "brew install stripe/stripe-cli/stripe"
    },
    {
      "id": "playwright-cli",
      "name": "playwright-cli",
      "kind": "cli",
      "detect": ["npm", "ls", "playwright-cli", "--depth=0"],
      "detect_contains": "playwright-cli@",
      "package": "playwright-cli",
      "install": ["npm", "install", "--save-dev", "playwright-cli"],
      "verify": ["npm", "ls", "playwright-cli", "--depth=0"],
      "verify_contains": "playwright-cli@",
      "manual_install": "npm install --save-dev playwright-cli"
    },
    {
      "id": "notebooklm-py",
      "name": "notebooklm-py",
      "kind": "cli",
      "detect": ["python3", "-m", "pip", "show", "notebooklm-py"],
      "install": ["python3", "-m", "pip", "install", "--no-cache-dir", "notebooklm-py"],
      "verify": ["python3", "-m", "pip", "show", "notebooklm-py"],
      "manual_install": "python3 -m pip install notebooklm-py"
    },
    {
      "id": "skills-sh",
      "name": "skills.sh",
      "kind": "url",
      "url": "https://skills.sh",
